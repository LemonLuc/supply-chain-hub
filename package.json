{
  "name": "supply-chain-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "slides": "slidev slides.md",
    "slides:build": "slidev build slides.md --out dist-slidev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "sanitize:cloudflare-env": "node scripts/sanitize-opennext-env.mjs",
    "deploy": "opennextjs-cloudflare build && npm run sanitize:cloudflare-env && opennextjs-cloudflare deploy -- --keep-vars",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "slides:deploy": "npm run slides:build && node -e \"require(\\\"fs\\\").rmSync(\\\"dist-slidev/_redirects\\\",{force:true})\" && wrangler deploy --config wrangler.deck.jsonc"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.85",
    "@ai-sdk/react": "latest",
    "@openai/agents": "0.13.4",
    "@opennextjs/cloudflare": "^1.19.11",
    "ai": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0",
    "@slidev/theme-default": "^0.25.0",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "playwright-chromium": "^1.61.0",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "^4.103.0"
  }
}
